# Moomoo Configuration
MOOMOO_UNLOCK_PASSWORD="your_trade_password_here"
MOOMOO_HOST="127.0.0.1"
MOOMOO_PORT=11111

# Questrade Configuration
# Questrade typically uses a ~/.questrade.json token locally, but if manual entry is preferred:
QUESTRADE_REFRESH_TOKEN="your_refresh_token_here"

# Application Config
CORS_ORIGINS="http://localhost:3000"
